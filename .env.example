# ============================================================
# Variables d'environnement — Pipeline génération d'images IA
# Copier ce fichier en .env puis remplir les valeurs.
# .env est dans .gitignore : NE JAMAIS le commiter.
# ============================================================

# --- Replicate (génération Flux 1.1 Pro Ultra) ---
# Récupérer sur : https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Cloudinary (CDN + transformations) ---
# Récupérer sur : https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
